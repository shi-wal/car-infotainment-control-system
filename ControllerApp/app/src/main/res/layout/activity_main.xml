<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A1A">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="28dp">

    <TextView
        android:text="CAR REMOTE"
        android:textColor="#00E5FF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:gravity="center"
        android:layout_marginBottom="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <TextView
        android:text="CONTROL PANEL"
        android:textColor="#546E7A"
        android:textSize="12sp"
        android:letterSpacing="0.3"
        android:gravity="center"
        android:layout_marginBottom="28dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/tvStatus"
        android:text="Volume: 50  |  AC: 22°C"
        android:textColor="#00E5FF"
        android:textSize="14sp"
        android:gravity="center"
        android:background="@drawable/bg_status_bar"
        android:padding="10dp"
        android:layout_marginBottom="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- Section: Media -->
    <TextView
        android:text="MEDIA"
        android:textColor="#546E7A"
        android:textSize="11sp"
        android:letterSpacing="0.2"
        android:layout_marginBottom="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btnMusic"
        android:text="🎵 Music OFF"
        android:textColor="#FFFFFF"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#C62828"
        style="@style/Widget.AppCompat.Button"/>

    <!-- Section: Cabin -->
    <TextView
        android:text="CABIN"
        android:textColor="#546E7A"
        android:textSize="11sp"
        android:letterSpacing="0.2"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btnLights"
        android:text="💡 Lights OFF"
        android:textColor="#FFFFFF"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#C62828"
        style="@style/Widget.AppCompat.Button"/>

    <Button
        android:id="@+id/btnLock"
        android:text="🔒 Door Locked"
        android:textColor="#FFFFFF"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#2E7D32"
        style="@style/Widget.AppCompat.Button"/>

    <!-- Section: Volume -->
    <TextView
        android:text="VOLUME"
        android:textColor="#546E7A"
        android:textSize="11sp"
        android:letterSpacing="0.2"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnVolDown"
            android:text="VOL −"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A237E"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:layout_width="0dp"
            android:layout_height="56dp"
            style="@style/Widget.AppCompat.Button"/>

        <Button
            android:id="@+id/btnVolUp"
            android:text="VOL +"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A237E"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="56dp"
            style="@style/Widget.AppCompat.Button"/>
    </LinearLayout>

    <!-- Section: AC -->
    <TextView
        android:text="AIR CONDITIONING"
        android:textColor="#546E7A"
        android:textSize="11sp"
        android:letterSpacing="0.2"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnACDown"
            android:text="AC −"
            android:textColor="#FFFFFF"
            android:backgroundTint="#004D40"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:layout_width="0dp"
            android:layout_height="56dp"
            style="@style/Widget.AppCompat.Button"/>

        <Button
            android:id="@+id/btnACUp"
            android:text="AC +"
            android:textColor="#FFFFFF"
            android:backgroundTint="#004D40"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="56dp"
            style="@style/Widget.AppCompat.Button"/>
    </LinearLayout>

</LinearLayout>
</ScrollView>